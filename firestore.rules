rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()       { return isAuth() && userRole() == 'admin'; }
    function isModo()        { return isAuth() && userRole() in ['modo', 'admin']; }
    function isContrib()     { return isAuth() && userRole() in ['contributeur', 'modo', 'admin']; }
    function isMembre()      { return isAuth() && userRole() in ['membre', 'contributeur', 'modo', 'admin']; }

    function creatorToolEnabled(toolType) {
      let cfg = get(/databases/$(database)/documents/config/creator);
      if (cfg == null) return true;
      let tools = cfg.data.get('tools', null);
      if (tools == null) return true;
      return tools.get(toolType, true) != false;
    }

    match /items/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /mobs/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /personnages/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /regions/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /users/{uid} {
      allow read:   if isAuth();
      // Création du propre profil à l'inscription (rôle forcé à 'membre', pas d'autres champs)
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'membre'
                    && request.resource.data.keys().hasOnly(['pseudo','role']);
      // Seul un admin peut modifier (changer le rôle, etc.)
      allow update, delete: if isAdmin();
    }

    match /config/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /submissions/{id} {
      // Tout le monde peut soumettre (invités inclus) — pseudo et type obligatoires
      // Les modo+ contournent les restrictions du creator
      allow create: if request.resource.data.submitterName is string
                    && request.resource.data.submitterName.size() >= 2
                    && request.resource.data.type in ['item','mob','pnj','region']
                    && request.resource.data.status == 'pending'
                    && (isModo() || creatorToolEnabled(request.resource.data.type));
      // Les modo+ voient tout ; un user connecté voit ses propres soumissions
      allow read:   if isModo() || (isAuth() && resource.data.submittedBy == request.auth.uid);
      // Seuls les modo/admin peuvent modifier (approuver/rejeter)
      allow update: if isModo();
      allow delete: if isModo();
    }

  }
}
