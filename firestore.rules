rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()       { return isAuth() && userRole() == 'admin'; }
    function isContrib()     { return isAuth() && userRole() in ['contributeur', 'admin']; }
    function isMembre()      { return isAuth() && userRole() in ['membre', 'contributeur', 'admin']; }

    function creatorToolEnabled(toolType) {
      return !exists(/databases/$(database)/documents/config/creator)
        || get(/databases/$(database)/documents/config/creator).data.get('tools', {}).get(toolType, true) != false;
    }

    match /items/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /mobs/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /personnages/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /regions/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /quetes/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /users/{uid} {
      allow read:   if isAuth() && (request.auth.uid == uid || isAdmin());
      // Création du propre profil à l'inscription (rôle forcé à 'membre', pas d'autres champs)
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'membre'
                    && request.resource.data.keys().hasOnly(['pseudo','role']);
      // Seul un admin peut modifier (changer le rôle, etc.)
      allow update, delete: if isAdmin();
    }

    match /config/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /submissions/{id} {
      // Tout le monde peut soumettre (invités inclus) — pseudo et type obligatoires
      // Les contributeurs+ contournent les restrictions du creator
      allow create: if request.resource.data.submitterName is string
                    && request.resource.data.submitterName.size() >= 2
                    && request.resource.data.type in ['item','mob','pnj','region','quest']
                    && request.resource.data.status == 'pending'
                    && (isContrib() || creatorToolEnabled(request.resource.data.type));
      // Les contributeurs+ voient tout ; un user connecté voit ses propres soumissions
      allow read:   if isContrib() || (isAuth() && resource.data.submittedBy == request.auth.uid);
      // Seuls les contributeurs/admin peuvent modifier (approuver/rejeter)
      allow update: if isContrib();
      allow delete: if isContrib();
    }

  }
}
