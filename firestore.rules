rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'visiteur';
    }

    function isAdmin()       { return isAuth() && userRole() == 'admin'; }
    function isContrib()     { return isAuth() && userRole() in ['contributeur', 'admin']; }
    function isMembre()      { return isAuth() && userRole() in ['membre', 'contributeur', 'admin']; }

    function creatorToolEnabled(toolType) {
      return !exists(/databases/$(database)/documents/config/creator)
        || get(/databases/$(database)/documents/config/creator).data.get('tools', {}).get(toolType, true) != false;
    }

    match /items/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    // Items sensibles — gameplay stocké sous hash(normalize(name))
    // get public (si on connaît le hash), list réservé aux contributeurs
    match /items_hidden/{hashId} {
      allow get:   if true;
      allow list:  if isContrib();
      allow write: if isContrib();
    }

    // Items sensibles — contenu flavor (lore, obtain, craft…), contrib only
    match /items_secret/{id} {
      allow read:  if isContrib();
      allow write: if isContrib();
    }

    match /mobs/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    // Mobs sensibles — doc complet, contrib only (jamais visible au public)
    // Bascule sensible ↔ non-sensible = déplacement entre mobs_secret et mobs
    match /mobs_secret/{id} {
      allow read:  if isContrib();
      allow write: if isContrib();
    }

    match /personnages/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /regions/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /quetes/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    // Panoplies — lecture publique, écriture admin uniquement
    match /panoplies/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow get:    if isAuth() && (request.auth.uid == uid || isAdmin());
      allow list:   if isAuth();  // pseudo uniqueness check (changePseudoSecurely)
      // Création du propre profil à l'inscription (rôle forcé à 'membre', pas d'autres champs)
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'membre'
                    && request.resource.data.keys().hasOnly(['pseudo','role','email']);
      // Self-update : l'utilisateur peut modifier son pseudo et son email (jamais son rôle)
      allow update: if isAdmin()
                    || (isAuth()
                        && request.auth.uid == uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pseudo','email'])
                        && request.resource.data.pseudo is string);
      allow delete: if isAdmin();
    }

    // Marqueurs carte (donjons, ressources, zones) — lecture publique, écriture contrib
    match /map_markers/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    // Donjons migrés depuis data.js — lecture publique, écriture contrib
    match /donjons/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    // Zones de spawn de monstres (polygones) — lecture publique, écriture contrib
    match /zones/{id} {
      allow read:  if true;
      allow write: if isContrib();
    }

    match /config/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Pseudo lookup map for leaderboard — users can update their own entry only
    match /config/pseudos {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.keys().hasOnly([request.auth.uid]);
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([request.auth.uid]);
      allow delete: if isAdmin();
    }

    // Corbeille — contribs peuvent écrire (soft-delete), admins gèrent
    match /trash/{id} {
      allow read:   if isContrib();
      allow create: if isContrib();
      allow delete: if isContrib();
    }

    // Posts Discord trackés (thread_id / message_id) — admin only
    match /discord_posts/{id} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    match /submissions/{id} {
      // Tout le monde peut soumettre (invités inclus) — pseudo et type obligatoires
      // Les contributeurs+ contournent les restrictions du creator
      allow create: if request.resource.data.submitterName is string
                    && request.resource.data.submitterName.size() >= 2
                    && request.resource.data.type in ['item','mob','pnj','region','quest','panoplie']
                    && request.resource.data.status == 'pending'
                    && (isContrib() || creatorToolEnabled(request.resource.data.type));
      // Les contributeurs+ voient tout ; un user connecté voit ses propres soumissions
      allow read:   if isContrib() || (isAuth() && resource.data.submittedBy == request.auth.uid);
      // Seuls les contributeurs/admin peuvent modifier (approuver/rejeter)
      allow update: if isContrib();
      allow delete: if isContrib();
    }

  }
}
